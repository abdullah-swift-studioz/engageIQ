# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
WEB_PORT=3000

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://engageiq:engageiq@localhost:5432/engageiq

# ─── ClickHouse ───────────────────────────────────────────────────────────────
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DATABASE=engageiq
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────────────────────────────
# JWT_SECRET must be at least 32 characters; JWT_REFRESH_SECRET must also be at least 32 characters
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_REFRESH_SECRET=change-me-to-another-random-string-at-least-32-chars
JWT_REFRESH_EXPIRES_IN=7d
JWT_ACCESS_EXPIRES_IN=1h

# ─── Shopify ──────────────────────────────────────────────────────────────────
# Required only when Shopify integration is active
# From Shopify Partner Dashboard > App Setup
SHOPIFY_API_KEY=your-shopify-api-key
SHOPIFY_API_SECRET=your-shopify-api-secret
# Comma-separated list of required OAuth scopes
SHOPIFY_SCOPES=read_customers,write_customers,read_orders,write_orders,read_products,read_inventory,write_inventory
# The public URL of this app (used for OAuth callback + webhook endpoint registration)
SHOPIFY_APP_URL=https://your-app-domain.com

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SES_FROM_EMAIL=no-reply@engageiq.io

# ─── WhatsApp (Meta Cloud API) ────────────────────────────────────────────────
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WEBHOOK_VERIFY_TOKEN=

# ─── SMS ──────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
PK_SMS_API_KEY=

# ─── AI / LLM ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Monitoring ───────────────────────────────────────────────────────────────
SENTRY_DSN=
