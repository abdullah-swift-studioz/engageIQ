# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
WEB_PORT=3000

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://engageiq:engageiq@localhost:5432/engageiq

# ─── ClickHouse ───────────────────────────────────────────────────────────────
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DATABASE=engageiq
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────────────────────────────
# JWT_SECRET must be at least 32 characters; JWT_REFRESH_SECRET must also be at least 32 characters
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_REFRESH_SECRET=change-me-to-another-random-string-at-least-32-chars
JWT_REFRESH_EXPIRES_IN=7d
JWT_ACCESS_EXPIRES_IN=1h

# ─── Shopify ──────────────────────────────────────────────────────────────────
# Required only when Shopify integration is active
# From Shopify Partner Dashboard > App Setup
SHOPIFY_API_KEY=your-shopify-api-key
SHOPIFY_API_SECRET=your-shopify-api-secret
# Comma-separated list of required OAuth scopes
SHOPIFY_SCOPES=read_customers,write_customers,read_orders,write_orders,read_products,read_inventory,write_inventory
# The public URL of this app (used for OAuth callback + webhook endpoint registration)
SHOPIFY_APP_URL=https://your-app-domain.com

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SES_FROM_EMAIL=no-reply@engageiq.io

# ─── WhatsApp (Meta Cloud API) ────────────────────────────────────────────────
# Permanent system-user access token — Meta App Dashboard → WhatsApp → API Setup
META_WHATSAPP_TOKEN=
# WhatsApp phone number id (NOT the phone number) — Meta App Dashboard → WhatsApp → API Setup
META_WHATSAPP_PHONE_NUMBER_ID=
# Arbitrary string you also enter in Meta webhook config; echoed back on the GET handshake
META_WEBHOOK_VERIFY_TOKEN=
# lane:channels — Meta App Secret — Meta App Dashboard → Settings → Basic. Verifies inbound webhook HMAC (X-Hub-Signature-256)
META_APP_SECRET=
# lane:channels — Graph API version for WhatsApp Cloud API calls (never hardcode in a URL)
META_API_VERSION=v21.0
# lane:channels — WhatsApp Business Account id; needed only to submit templates to Meta (blank = local PENDING)
META_WHATSAPP_BUSINESS_ACCOUNT_ID=

# ─── SMS ──────────────────────────────────────────────────────────────────────
# lane:sms — which provider the adapter tries first ('twilio' | 'pk-aggregator'); other is failover
SMS_PRIMARY_PROVIDER=twilio
# Twilio (global) — console.twilio.com → Account SID + Auth Token; From is an SMS-capable number
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# lane:sms — optional Twilio Messaging Service SID (sender pool); used instead of TWILIO_FROM_NUMBER when set
TWILIO_MESSAGING_SERVICE_SID=
# lane:sms — public URL Twilio POSTs delivery-status callbacks to (this app's /webhooks/sms)
TWILIO_STATUS_CALLBACK_URL=
# Local PK SMS aggregator (domestic fallback) — vendor TBD; API key from the gateway
PK_SMS_API_KEY=
# lane:sms — PK aggregator JSON send endpoint URL
PK_SMS_API_URL=
# lane:sms — sender id / mask for the PK aggregator (optional)
PK_SMS_SENDER_ID=
# lane:sms — public base URL (scheme+host) for verifying Twilio signatures behind a proxy
PUBLIC_BASE_URL=

# ─── Email (lane:email — roadmap 6.4) ─────────────────────────────────────────
# Display name on the From header; the address itself is AWS_SES_FROM_EMAIL above.
EMAIL_FROM_NAME=EngageIQ
# Public base URL for email open-tracking pixels + unsubscribe links.
EMAIL_TRACKING_BASE_URL=http://localhost:3001
# Optional Resend API key — fallback sender used only when AWS SES creds are absent.
RESEND_API_KEY=

# ─── AI / LLM ─────────────────────────────────────────────────────────────────
# Anthropic API key for the AI copywriter — get one at https://console.anthropic.com/settings/keys
# When absent, the "Generate with AI" endpoint returns AI_NOT_CONFIGURED (no fake copy).
ANTHROPIC_API_KEY=
# lane:copywriter — Anthropic model + generation tuning (optional; sensible defaults in env.ts)
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_COPYWRITER_MAX_TOKENS=1024
ANTHROPIC_COPYWRITER_EFFORT=low

# ─── Monitoring ───────────────────────────────────────────────────────────────
SENTRY_DSN=

# ─── ML Service (lane:ml) ─────────────────────────────────────────────────────
# Base URL of the Python FastAPI ML microservice (apps/ml-service); runs on :8000.
ML_SERVICE_URL=http://localhost:8000
# Per-request timeout (ms) for ML service calls.
ML_SERVICE_TIMEOUT_MS=30000
# Cron for the daily RFM/churn/LTV/fake-order/recommendations scoring run.
ML_SCORING_CRON=0 3 * * *
# Cron for the weekly AI segment-discovery run.
ML_SEGMENT_DISCOVERY_CRON=0 4 * * 0
# Set false to skip auto-registering the repeatable scoring schedulers on worker boot.
ML_SCHEDULER_ENABLED=true

# ─── Web Push (lane:push) ─────────────────────────────────────────────────────
# Self-hosted Web Push Protocol VAPID keypair. Generate once with:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"   (run in apps/api)
#   or: npx web-push generate-vapid-keys
# Both optional — the app boots without them; the PushAdapter returns "push not configured"
# until set. The PUBLIC key is safe to expose to browsers; keep the PRIVATE key server-side.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact URI push services use to reach you (mailto: or https:).
VAPID_SUBJECT=mailto:push@engageiq.app
# ─── Courier Integrations (lane:courier) ──────────────────────────────────────
# AES-256-GCM key encrypting MerchantIntegration.credentials (courier API keys) at rest.
# 32 bytes as 64 hex chars OR base64. Generate: openssl rand -hex 32
# Leave blank locally — adapters then no-op with a clear status instead of storing secrets.
COURIER_CREDENTIALS_KEY=
# Cron for the repeatable courier status sweep (enqueues a poll per active shipment).
COURIER_POLL_CRON=*/30 * * * *
# Set true to auto-register the repeatable courier sweep scheduler on worker boot.
COURIER_POLL_ENABLED=false
# ─── Outbound webhooks (lane:public-api) ──────────────────────────────────────
# AES-256-GCM master key for encrypting merchant webhook signing secrets at rest.
# Generate with: openssl rand -base64 32   (leave blank in dev to derive from JWT_SECRET)
WEBHOOK_ENCRYPTION_KEY=
WEBHOOK_DELIVERY_TIMEOUT_MS=10000
