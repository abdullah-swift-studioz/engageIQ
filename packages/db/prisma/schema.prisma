generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Plan {
  STARTER
  GROWTH
  PRO
  ENTERPRISE
}

enum Role {
  OWNER
  ADMIN
  MARKETER
  ANALYST
  AGENCY_ADMIN
  AGENCY_MEMBER
}

enum Channel {
  EMAIL
  SMS
  WHATSAPP
  PUSH
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  PAUSED
  CANCELLED
}

enum JourneyStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum JourneyStepType {
  TRIGGER
  ACTION
  CONDITION
  DELAY
  AB_SPLIT
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  EXITED
  FAILED
}

enum CodOrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  RETURNED
  CANCELLED
}

enum CodVerificationStatus {
  UNVERIFIED
  PENDING_VERIFICATION
  VERIFIED
  AUTO_CANCELLED
}

enum RfmSegment {
  CHAMPION
  LOYAL
  POTENTIAL_LOYALIST
  NEW_CUSTOMER
  PROMISING
  NEED_ATTENTION
  ABOUT_TO_SLEEP
  AT_RISK
  CANNOT_LOSE_THEM
  HIBERNATING
  LOST
}

enum ChurnRiskLabel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ReEntryRule {
  ALLOW
  DISALLOW
  RE_ENROLL_AFTER_EXIT
}

// ─── Phase 0 freeze: Channels / Campaigns / ML enums ──────────────────────────

enum MessageDirection {
  OUTBOUND
  INBOUND
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
  RECEIVED
}

enum TemplateStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum TemplateCategory {
  UTILITY
  MARKETING
}

enum CampaignRecipientStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
  SKIPPED
}

enum RecommendationType {
  ALSO_BOUGHT
  MIGHT_LIKE
  COMPLETE_LOOK
  RESTOCK
}

// ─── Freeze v2: Wave-2 enums (email, on-site, cod-verify, courier, a/b, agency) ──

enum Courier {
  POSTEX
  LEOPARDS
  TCS
  MP
  OTHER // freeze-v2: escape hatch for couriers beyond the core 4 (BlueEx/Trax/Swyft/…) — avoids a future migration
}

enum VerificationChannel {
  WHATSAPP
  SMS
  IVR
}

enum VerificationStatus {
  PENDING // queued, not yet sent
  AWAITING // sent, awaiting customer reply
  CONFIRMED // customer confirmed (YES)
  CANCELLED // customer cancelled (NO)
  NO_RESPONSE // reply window elapsed → auto-cancel candidate
  FAILED // send/call failed
}

enum OnSiteElementType {
  POPUP
  STICKY_BAR
  EMBED // freeze-v2: inline/embedded storefront content (e.g. product-page restock block)
}

enum AbTestStatus {
  DRAFT
  RUNNING
  PAUSED
  WINNER_DECIDED // winner chosen; rolling out to the remaining audience
  COMPLETED
  CANCELLED
}

enum AbTestEntityType {
  CAMPAIGN
  EMAIL_TEMPLATE
  ONSITE_ELEMENT
}

enum ShipmentStatus {
  CREATED
  DISPATCHED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  ATTEMPTED // delivery attempted, customer unavailable → reattempt
  DELIVERED
  RETURN_IN_TRANSIT // RTO leg in progress
  RETURNED
  UNDELIVERABLE
  CANCELLED
}

enum WhatsAppConversationState {
  OPEN
  AWAITING_REPLY
  CLOSED
  EXPIRED
}

// ─── Merchants ────────────────────────────────────────────────────────────────

model Merchant {
  id                   String    @id @default(cuid())
  name                 String
  shopifyDomain        String?   @unique @map("shopify_domain")
  shopifyAccessToken   String?   @map("shopify_access_token")
  shopifyShopId        String?   @map("shopify_shop_id")
  shopifyScope         String?   @map("shopify_scope")
  shopifyInstalledAt   DateTime? @map("shopify_installed_at")
  shopifyUninstalledAt DateTime? @map("shopify_uninstalled_at")
  plan                 Plan      @default(STARTER)
  timezone             String    @default("Asia/Karachi")
  currency             String    @default("PKR")
  isActive             Boolean   @default(true) @map("is_active")
  backfillCompletedAt  DateTime? @map("backfill_completed_at")

  // freeze-v2: billing / subscription (roadmap 8.3 — PKR pricing plans). PLACEHOLDERs: no billing engine yet.
  subscriptionStatus String?   @map("subscription_status") // "trialing"|"active"|"past_due"|"frozen"|"cancelled"
  shopifyChargeId    String?   @map("shopify_charge_id") // Shopify recurring-application-charge id
  trialEndsAt        DateTime? @map("trial_ends_at")
  currentPeriodEnd   DateTime? @map("current_period_end")
  priceOverride      Decimal?  @map("price_override") @db.Decimal(12, 2)

  // Agency parent/child: an agency merchant can own child merchants
  agencyId String?    @map("agency_id")
  agency   Merchant?  @relation("AgencyChildren", fields: [agencyId], references: [id])
  children Merchant[] @relation("AgencyChildren")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  users              User[]
  customers          Customer[]
  segments           Segment[]
  campaigns          Campaign[]
  journeys           Journey[]
  codOrders          CodOrder[]
  orders             Order[]
  abandonedCheckouts AbandonedCheckout[]
  apiKeys            ApiKey[]

  // Phase 0 freeze back-relations
  whatsappTemplates  WhatsAppTemplate[]
  messages           Message[]
  campaignRecipients CampaignRecipient[]
  products           Product[]
  recommendations    Recommendation[]
  modelRuns          ModelRun[]
  savedViews         SavedView[]

  // freeze-v2 back-relations
  emailTemplates            EmailTemplate[]
  emailSuppressions         EmailSuppression[]
  sendingDomains            SendingDomain[]
  abTests                   AbTest[]
  onSiteElements            OnSiteElement[]
  verificationAttempts      VerificationAttempt[]
  whatsappConversations     WhatsAppConversation[]
  pushSubscriptions         PushSubscription[]
  courierShipments          CourierShipment[]
  courierEvents             CourierEvent[]
  outboundWebhooks          OutboundWebhook[]
  webhookDeliveries         WebhookDelivery[]
  merchantIntegrations      MerchantIntegration[]
  aiGenerations             AiGeneration[]
  settings                  MerchantSettings?
  agencyAssignmentsAsAgency AgencyAssignment[]     @relation("AgencyAssignmentAgency")
  agencyAssignmentsAsChild  AgencyAssignment[]     @relation("AgencyAssignmentChild")

  @@map("merchants")
}

// ─── Users (dashboard users) ─────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  merchantId   String    @map("merchant_id")
  email        String
  passwordHash String    @map("password_hash")
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  role         Role      @default(MARKETER)
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  // freeze-v2 back-relation
  agencyAssignments AgencyAssignment[]

  @@unique([merchantId, email])
  @@index([merchantId])
  @@map("users")
}

// ─── Customers ────────────────────────────────────────────────────────────────

model Customer {
  id                String  @id @default(cuid())
  merchantId        String  @map("merchant_id")
  shopifyCustomerId String? @map("shopify_customer_id")

  // Identity
  email              String?
  phone              String? // E.164 format
  firstName          String?  @map("first_name")
  lastName           String?  @map("last_name")
  city               String?
  province           String?
  country            String   @default("PK")
  languagePreference String?  @map("language_preference") // "en" | "ur"
  tags               String[] @default([])

  // Shopify aggregates (kept in sync by webhook processor)
  totalOrders   Int       @default(0) @map("total_orders")
  totalSpent    Decimal   @default(0) @map("total_spent") @db.Decimal(12, 2)
  avgOrderValue Decimal   @default(0) @map("avg_order_value") @db.Decimal(10, 2)
  firstOrderAt  DateTime? @map("first_order_at")
  lastOrderAt   DateTime? @map("last_order_at")

  // Behavioral (from ClickHouse, synced periodically)
  lastSeenAt   DateTime? @map("last_seen_at")
  sessionCount Int       @default(0) @map("session_count")

  // RFM scoring (computed by daily batch job in Phase 4)
  rfmSegment        RfmSegment? @map("rfm_segment")
  rfmRecencyScore   Int?        @map("rfm_recency_score") // 1–5
  rfmFrequencyScore Int?        @map("rfm_frequency_score") // 1–5
  rfmMonetaryScore  Int?        @map("rfm_monetary_score") // 1–5
  rfmScoredAt       DateTime?   @map("rfm_scored_at")

  // AI scores (computed by Python microservice in Phase 7)
  churnScore     Float?          @map("churn_score") // 0–100 (see CHURN_SCORE in @engageiq/shared; Feature Guide §8.1)
  churnRiskLabel ChurnRiskLabel? @map("churn_risk_label")
  churnScoredAt  DateTime?       @map("churn_scored_at")
  ltv90d         Decimal?        @map("ltv_90d") @db.Decimal(12, 2)
  ltv180d        Decimal?        @map("ltv_180d") @db.Decimal(12, 2)
  ltv365d        Decimal?        @map("ltv_365d") @db.Decimal(12, 2)
  ltvScoredAt    DateTime?       @map("ltv_scored_at")
  // freeze-v2 PLACEHOLDER: AI-computed next best action (Feature Guide §4.3) — no producer yet
  nextBestAction String?         @map("next_best_action")

  // COD profile
  codOrderCount     Int     @default(0) @map("cod_order_count")
  codAcceptanceRate Float?  @map("cod_acceptance_rate") // 0–1
  codRejectionRate  Float?  @map("cod_rejection_rate") // 0–1
  fakeOrderScore    Float?  @map("fake_order_score") // 0–100
  isBlocked         Boolean @default(false) @map("is_blocked")

  // Channel opt-ins
  isSubscribedEmail    Boolean @default(true) @map("is_subscribed_email")
  isSubscribedSms      Boolean @default(true) @map("is_subscribed_sms")
  isSubscribedWhatsapp Boolean @default(true) @map("is_subscribed_whatsapp")
  isSubscribedPush     Boolean @default(true) @map("is_subscribed_push") // freeze-v2

  // Anonymous ID linking (from Storefront SDK)
  anonIds String[] @default([]) @map("anon_ids")

  // Multi-store unification (Phase 3)
  groupCustomerId String? @map("group_customer_id")

  // Identity resolution (Phase 3)
  mergedIntoId String?   @map("merged_into_id")
  mergedAt     DateTime? @map("merged_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  merchant           Merchant            @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  segmentMemberships SegmentMembership[]
  journeyEnrollments JourneyEnrollment[]
  codOrders          CodOrder[]
  orders             Order[]
  abandonedCheckouts AbandonedCheckout[]

  // Phase 0 freeze back-relations
  messages           Message[]
  campaignRecipients CampaignRecipient[]
  recommendations    Recommendation[]

  // freeze-v2 back-relations
  pushSubscriptions     PushSubscription[]
  whatsappConversations WhatsAppConversation[]
  verificationAttempts  VerificationAttempt[]
  courierShipments      CourierShipment[]

  @@unique([merchantId, shopifyCustomerId])
  @@unique([merchantId, email])
  @@index([merchantId])
  @@index([merchantId, rfmSegment])
  @@index([merchantId, churnRiskLabel])
  @@index([groupCustomerId])
  // Phase 0 freeze: WhatsApp inbound webhook matches customer by (merchantId, phone) on a hot path
  @@index([merchantId, phone])
  @@map("customers")
}

// ─── Segments ─────────────────────────────────────────────────────────────────

model Segment {
  id              String    @id @default(cuid())
  merchantId      String    @map("merchant_id")
  name            String
  description     String?
  conditions      Json // The condition tree (Phase 5 segment builder format)
  isDynamic       Boolean   @default(true) @map("is_dynamic")
  memberCount     Int       @default(0) @map("member_count")
  lastEvaluatedAt DateTime? @map("last_evaluated_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  merchant    Merchant            @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  memberships SegmentMembership[]
  campaigns   Campaign[]

  // freeze-v2 back-relation
  onSiteElements OnSiteElement[]

  @@index([merchantId])
  @@map("segments")
}

model SegmentMembership {
  id         String    @id @default(cuid())
  segmentId  String    @map("segment_id")
  customerId String    @map("customer_id")
  enteredAt  DateTime  @default(now()) @map("entered_at")
  exitedAt   DateTime? @map("exited_at") // null = currently a member

  segment  Segment  @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([segmentId, customerId])
  @@index([segmentId, customerId, exitedAt])
  @@index([customerId])
  @@map("segment_memberships")
}

// ─── Campaigns ────────────────────────────────────────────────────────────────

model Campaign {
  id         String         @id @default(cuid())
  merchantId String         @map("merchant_id")
  name       String
  channel    Channel
  status     CampaignStatus @default(DRAFT)
  segmentId  String?        @map("segment_id")

  // Content
  subject String?
  content Json // Channel-specific content payload

  // Scheduling
  sendAt DateTime? @map("send_at")
  sentAt DateTime? @map("sent_at")

  // Analytics
  recipientCount    Int     @default(0) @map("recipient_count")
  deliveredCount    Int     @default(0) @map("delivered_count")
  openedCount       Int     @default(0) @map("opened_count")
  clickedCount      Int     @default(0) @map("clicked_count")
  unsubscribedCount Int     @default(0) @map("unsubscribed_count")
  revenueAttributed Decimal @default(0) @map("revenue_attributed") @db.Decimal(12, 2)

  // Attribution tracking
  utmCampaign String? @map("utm_campaign")
  utmSource   String? @map("utm_source")
  utmMedium   String? @map("utm_medium")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  segment  Segment? @relation(fields: [segmentId], references: [id])

  // Phase 0 freeze back-relations
  messages   Message[]
  recipients CampaignRecipient[]

  @@index([merchantId])
  @@index([merchantId, status])
  @@map("campaigns")
}

// ─── Journeys ─────────────────────────────────────────────────────────────────

model Journey {
  id                    String        @id @default(cuid())
  merchantId            String        @map("merchant_id")
  name                  String
  description           String?
  triggerType           String        @map("trigger_type") // e.g. "order_placed", "segment_entered"
  triggerConfig         Json          @map("trigger_config")
  status                JourneyStatus @default(DRAFT)
  reEntryRule           ReEntryRule   @default(DISALLOW) @map("re_entry_rule")
  exitTrigger           String?       @map("exit_trigger") // e.g. "order_placed" — single exit trigger per journey
  // freeze-v2: provenance when this journey was instantiated from a FlowTemplate (6.5). Soft key, not an FK
  // (FlowTemplate rows can be retired via isActive without breaking existing journeys).
  sourceFlowTemplateKey String?       @map("source_flow_template_key")

  // Analytics
  enrollmentCount Int @default(0) @map("enrollment_count")
  completionCount Int @default(0) @map("completion_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  merchant    Merchant            @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  steps       JourneyStep[]
  enrollments JourneyEnrollment[]

  @@index([merchantId])
  @@index([merchantId, status])
  @@map("journeys")
}

model JourneyStep {
  id           String          @id @default(cuid())
  journeyId    String          @map("journey_id")
  parentStepId String?         @map("parent_step_id")
  stepType     JourneyStepType @map("step_type")
  config       Json // step-type-specific configuration
  positionX    Int             @default(0) @map("position_x") // canvas coordinates
  positionY    Int             @default(0) @map("position_y")
  label        String?

  createdAt DateTime @default(now()) @map("created_at")

  journey     Journey             @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  parentStep  JourneyStep?        @relation("StepChildren", fields: [parentStepId], references: [id])
  childSteps  JourneyStep[]       @relation("StepChildren")
  enrollments JourneyEnrollment[]

  @@index([journeyId])
  @@map("journey_steps")
}

model JourneyEnrollment {
  id            String           @id @default(cuid())
  journeyId     String           @map("journey_id")
  customerId    String           @map("customer_id")
  currentStepId String?          @map("current_step_id")
  status        EnrollmentStatus @default(ACTIVE)
  enrolledAt    DateTime         @default(now()) @map("enrolled_at")
  completedAt   DateTime?        @map("completed_at")
  exitedAt      DateTime?        @map("exited_at")
  lastStepAt    DateTime?        @map("last_step_at")
  metadata      Json? // context data passed along the journey

  journey     Journey      @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  customer    Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  currentStep JourneyStep? @relation(fields: [currentStepId], references: [id])

  // Phase 0 freeze back-relation
  messages Message[]

  // freeze-v2 back-relation
  whatsappConversations WhatsAppConversation[]

  @@index([journeyId, customerId, status])
  @@index([customerId])
  @@index([journeyId, status])
  @@map("journey_enrollments")
}

// ─── COD Orders ───────────────────────────────────────────────────────────────

model CodOrder {
  id                    String                @id @default(cuid())
  merchantId            String                @map("merchant_id")
  customerId            String?               @map("customer_id")
  shopifyOrderId        String                @map("shopify_order_id")
  orderNumber           String                @map("order_number")
  amount                Decimal               @db.Decimal(12, 2)
  city                  String?
  province              String?
  courier               String?
  paymentGateway        String                @map("payment_gateway")
  status                CodOrderStatus        @default(PENDING)
  verificationStatus    CodVerificationStatus @default(UNVERIFIED) @map("verification_status")
  fakeScore             Float?                @map("fake_score") // 0–100
  fakeScoreDetails      Json?                 @map("fake_score_details")
  verificationSentAt    DateTime?             @map("verification_sent_at")
  verificationRepliedAt DateTime?             @map("verification_replied_at")
  placedAt              DateTime              @map("placed_at")
  deliveredAt           DateTime?             @map("delivered_at")
  returnedAt            DateTime?             @map("returned_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  merchant Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id])

  // freeze-v2 back-relations
  verificationAttempts VerificationAttempt[]
  courierShipments     CourierShipment[]

  @@unique([merchantId, shopifyOrderId])
  @@index([merchantId])
  @@index([merchantId, status])
  @@index([customerId])
  @@map("cod_orders")
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id                String    @id @default(cuid())
  merchantId        String    @map("merchant_id")
  customerId        String?   @map("customer_id")
  shopifyOrderId    String    @map("shopify_order_id")
  orderNumber       String    @map("order_number")
  totalPrice        Decimal   @map("total_price") @db.Decimal(12, 2)
  subtotalPrice     Decimal   @map("subtotal_price") @db.Decimal(12, 2)
  currency          String    @default("PKR")
  financialStatus   String?   @map("financial_status") // paid, pending, refunded, voided
  fulfillmentStatus String?   @map("fulfillment_status") // fulfilled, partial, null
  paymentGateway    String?   @map("payment_gateway")
  isCod             Boolean   @default(false) @map("is_cod")
  lineItems         Json      @map("line_items") // [{product_id, variant_id, title, quantity, price, sku}]
  shippingAddress   Json?     @map("shipping_address")
  tags              String[]  @default([])
  cancelledAt       DateTime? @map("cancelled_at")
  cancelReason      String?   @map("cancel_reason")
  refundedAmount    Decimal   @default(0) @map("refunded_amount") @db.Decimal(12, 2)
  // Phase 0 freeze: per-line return detail so Lane C can compute Product.returnRate (unit-level).
  // PLACEHOLDER: refund.processor must populate [{ product_id, line_item_id, quantity, subtotal }].
  returnsData       Json?     @map("returns_data")
  placedAt          DateTime  @map("placed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  merchant Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id])

  // freeze-v2 back-relation
  courierShipments CourierShipment[]

  @@unique([merchantId, shopifyOrderId])
  @@index([merchantId])
  @@index([customerId])
  @@index([merchantId, placedAt])
  @@index([merchantId, isCod])
  @@map("orders")
}

// ─── Abandoned Checkouts ──────────────────────────────────────────────────────

model AbandonedCheckout {
  id                   String    @id @default(cuid())
  merchantId           String    @map("merchant_id")
  customerId           String?   @map("customer_id")
  shopifyCheckoutToken String    @map("shopify_checkout_token")
  email                String?
  phone                String?
  lineItems            Json      @map("line_items")
  totalPrice           Decimal   @map("total_price") @db.Decimal(12, 2)
  currency             String    @default("PKR")
  abandonedAt          DateTime? @map("abandoned_at")
  recoveredAt          DateTime? @map("recovered_at")
  recoveredOrderId     String?   @map("recovered_order_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  merchant Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id])

  @@unique([merchantId, shopifyCheckoutToken])
  @@index([merchantId])
  @@index([customerId])
  @@map("abandoned_checkouts")
}

// ─── API Keys ─────────────────────────────────────────────────────────────────

model ApiKey {
  id         String    @id @default(cuid())
  merchantId String    @map("merchant_id")
  name       String
  keyHash    String    @unique @map("key_hash") // bcrypt hash of the full key
  keyPrefix  String    @map("key_prefix") // first 12 chars e.g. "eiq_live_abc" for display
  scopes     String[]  @default([]) // freeze-v2: public REST API per-key scoping (8.2)
  isActive   Boolean   @default(true) @map("is_active")
  lastUsedAt DateTime? @map("last_used_at")
  expiresAt  DateTime? @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([keyPrefix])
  @@map("api_keys")
}

// ─── Phase 0 freeze: Channels / Messaging ─────────────────────────────────────
// Frozen for Lane A (Channels) per docs/superpowers/specs/2026-06-26-whatsapp-channel-adapter-design.md

model WhatsAppTemplate {
  id              String           @id @default(cuid())
  merchantId      String           @map("merchant_id")
  name            String
  // Meta language code, e.g. "en", "en_US", "ur", "ar_AE" — free string, NOT an enum
  language        String
  category        TemplateCategory
  bodyText        String           @map("body_text") // body with {{1}}, {{2}} … placeholders
  variableMap     Json             @map("variable_map") // ordered [{ index, field, default? }]
  status          TemplateStatus   @default(DRAFT)
  metaTemplateId  String?          @map("meta_template_id") // Meta-assigned id after submit
  rejectionReason String?          @map("rejection_reason") // populated on REJECTED (UI needs it)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  merchant Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([merchantId, name, language])
  @@index([merchantId])
  @@map("whatsapp_templates")
}

model Message {
  id                  String           @id @default(cuid())
  merchantId          String           @map("merchant_id")
  customerId          String?          @map("customer_id") // nullable: inbound from unknown number
  channel             Channel
  direction           MessageDirection
  templateId          String?          @map("template_id") // null for free-form / inbound
  providerMessageId   String?          @unique @map("provider_message_id") // Meta wamid; @unique for status-webhook lookup + idempotency
  status              MessageStatus    @default(QUEUED)
  errorCode           String?          @map("error_code")
  errorTitle          String?          @map("error_title")
  body                String
  toPhone             String           @map("to_phone") // E.164 (WHATSAPP/SMS); email/push use the '' sentinel
  fromPhone           String?          @map("from_phone") // set for inbound
  journeyEnrollmentId String?          @map("journey_enrollment_id") // attribution (nullable)
  campaignId          String?          @map("campaign_id") // attribution (nullable)
  sentAt              DateTime?        @map("sent_at")
  deliveredAt         DateTime?        @map("delivered_at")
  readAt              DateTime?        @map("read_at")
  failedAt            DateTime?        @map("failed_at")

  // freeze-v2: cross-channel fields so EMAIL/PUSH sends log into the same Message table (6.4).
  toEmail         String?   @map("to_email") // email destination (channel = EMAIL)
  subject         String? // rendered send-time subject (email)
  bodyHtml        String?   @map("body_html") // PLACEHOLDER: rendered email HTML (body holds text)
  emailTemplateId String?   @map("email_template_id") // PLACEHOLDER: source EmailTemplate
  openedAt        DateTime? @map("opened_at") // PLACEHOLDER: email open (7.3 A/B, engagement stats)
  clickedAt       DateTime? @map("clicked_at") // PLACEHOLDER: email/push click
  metadata        Json? // PLACEHOLDER: channel-specific render fields (push title/url/icon)

  createdAt DateTime @default(now()) @map("created_at")

  merchant          Merchant           @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  customer          Customer?          @relation(fields: [customerId], references: [id])
  template          WhatsAppTemplate?  @relation(fields: [templateId], references: [id])
  journeyEnrollment JourneyEnrollment? @relation(fields: [journeyEnrollmentId], references: [id])
  campaign          Campaign?          @relation(fields: [campaignId], references: [id])
  campaignRecipient CampaignRecipient? // 1:1 back-relation (CampaignRecipient.messageId @unique)

  // freeze-v2 relations
  emailTemplate        EmailTemplate?        @relation(fields: [emailTemplateId], references: [id], onDelete: SetNull)
  verificationAttempts VerificationAttempt[]

  @@index([merchantId])
  @@index([customerId])
  @@index([merchantId, channel, direction])
  @@index([emailTemplateId])
  @@map("messages")
}

// ─── Phase 0 freeze: Campaigns ────────────────────────────────────────────────
// Frozen for Lane B (Campaign Engine). Per-recipient rows give idempotent blasts
// (@@unique([campaignId, customerId])), per-recipient resend, and attribution.

model CampaignRecipient {
  id          String                  @id @default(cuid())
  merchantId  String                  @map("merchant_id")
  campaignId  String                  @map("campaign_id")
  customerId  String                  @map("customer_id")
  status      CampaignRecipientStatus @default(PENDING)
  messageId   String?                 @unique @map("message_id") // FK to Message (wamid lives on Message)
  // freeze-v2: A/B variant assignment (id references an element inside AbTest.variants Json, not a table row)
  abVariantId String?                 @map("ab_variant_id")
  sentAt      DateTime?               @map("sent_at")
  failedAt    DateTime?               @map("failed_at")

  createdAt DateTime @default(now()) @map("created_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  message  Message? @relation(fields: [messageId], references: [id])

  @@unique([campaignId, customerId])
  @@index([merchantId])
  @@index([campaignId, status])
  @@map("campaign_recipients")
}

// ─── Phase 0 freeze: Product catalog ──────────────────────────────────────────
// Frozen to unblock product-level retention analytics (4.5), recommendations (7.2),
// and email dynamic blocks at once. Variants kept as Json (not normalized) — Phase 0
// tradeoff. No Order→Product FK; analytics join via lineItems.product_id + shopify_product_id.

model Product {
  id               String   @id @default(cuid())
  merchantId       String   @map("merchant_id")
  shopifyProductId String   @map("shopify_product_id")
  title            String
  handle           String?
  vendor           String?
  productType      String?  @map("product_type")
  status           String? // "active" | "archived"
  imageUrl         String?  @map("image_url")
  priceMin         Decimal? @map("price_min") @db.Decimal(12, 2)
  priceMax         Decimal? @map("price_max") @db.Decimal(12, 2)
  tags             String[] @default([])
  variants         Json? // [{ id, title, price, sku, inventory }]

  // Product-level retention analytics — PLACEHOLDERS: nullable, no engine writes these yet (Lane C/D fill later)
  repurchaseRate90d       Float?    @map("repurchase_rate_90d")
  crossSellRate           Float?    @map("cross_sell_rate")
  returnRate              Float?    @map("return_rate")
  avgBuyerLtv             Decimal?  @map("avg_buyer_ltv") @db.Decimal(12, 2)
  avgDaysToSecondPurchase Float?    @map("avg_days_to_second_purchase")
  analyticsComputedAt     DateTime? @map("analytics_computed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@unique([merchantId, shopifyProductId])
  @@index([merchantId])
  @@map("products")
}

// ─── Phase 0 freeze: ML / AI ──────────────────────────────────────────────────
// Frozen for Lane D (ML service). Recommendation = rec cache; ModelRun = run audit.
// PLACEHOLDERS: both tables have no producer yet — Lane D's Python service fills them.

model Recommendation {
  id          String             @id @default(cuid())
  merchantId  String             @map("merchant_id")
  customerId  String             @map("customer_id")
  type        RecommendationType
  productIds  String[]           @default([]) @map("product_ids") // ordered Shopify product ids (no array FK)
  score       Float?
  generatedAt DateTime           @default(now()) @map("generated_at")
  expiresAt   DateTime?          @map("expires_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([merchantId, customerId, type])
  @@index([merchantId, customerId])
  @@map("recommendations")
}

model ModelRun {
  id           String   @id @default(cuid())
  merchantId   String?  @map("merchant_id") // nullable: some runs global, some per-merchant
  modelName    String   @map("model_name")
  modelVersion String   @map("model_version")
  status       String   @default("success")
  rowCount     Int?     @map("row_count")
  durationMs   Int?     @map("duration_ms")
  runAt        DateTime @default(now()) @map("run_at")
  metadata     Json?

  merchant Merchant? @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([modelName, runAt])
  @@map("model_runs")
}

// ─── Phase 0 freeze: Analytics saved views ────────────────────────────────────
// Frozen for Lane C (Analytics). One generic table persists funnel + cohort + other
// saved configs so Lane C never needs a mid-wave migration. PLACEHOLDER: no producer yet.

model SavedView {
  id         String @id @default(cuid())
  merchantId String @map("merchant_id")
  type       String // "FUNNEL" | "COHORT" | "OTHER"
  name       String
  config     Json

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId, type])
  @@map("saved_views")
}

// ═══════════════════════════════════════════════════════════════════════════════
// Freeze v2 — Wave-2 tables (email, on-site, cod-verify, courier, webhooks, push,
// flow-library, agency, per-merchant settings/integrations, AI copy).
// Tables/columns only — no feature logic. Every merchant table carries a direct
// merchantId + FK onDelete:Cascade + @@index([merchantId]). Two deliberate
// exceptions: FlowTemplate (system/global) and AgencyAssignment (cross-merchant map).
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Email (roadmap 6.4 / guide 7.3) ──────────────────────────────────────────

model EmailTemplate {
  id              String  @id @default(cuid())
  merchantId      String  @map("merchant_id")
  name            String
  subject         String? // nullable: drafts; may carry personalization tokens
  preheader       String? // PLACEHOLDER: email preheader text
  blocks          Json // drag-drop section structure [{ type, ... }]
  status          String  @default("DRAFT") // "DRAFT" | "ACTIVE" | "ARCHIVED" (String: not in the requested enum set)
  isTransactional Boolean @default(false) @map("is_transactional")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  merchant Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([merchantId])
  @@map("email_templates")
}

model EmailSuppression {
  id           String   @id @default(cuid())
  merchantId   String   @map("merchant_id")
  email        String
  reason       String // "hard_bounce" | "complaint" | "manual"
  suppressedAt DateTime @default(now()) @map("suppressed_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@unique([merchantId, email])
  @@index([merchantId])
  @@map("email_suppressions")
}

model SendingDomain {
  id             String    @id @default(cuid())
  merchantId     String    @map("merchant_id")
  domain         String
  status         String    @default("PENDING") // "PENDING" | "VERIFIED" | "FAILED"
  dkimVerified   Boolean   @default(false) @map("dkim_verified")
  spfVerified    Boolean   @default(false) @map("spf_verified")
  dmarcVerified  Boolean   @default(false) @map("dmarc_verified")
  dnsRecords     Json?     @map("dns_records") // PLACEHOLDER: required DNS records to publish
  dedicatedIp    String?   @map("dedicated_ip") // PLACEHOLDER: Pro-plan dedicated IP
  sesIdentityArn String?   @map("ses_identity_arn") // PLACEHOLDER: AWS SES identity ref
  verifiedAt     DateTime? @map("verified_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@unique([merchantId, domain])
  @@index([merchantId])
  @@map("sending_domains")
}

// ─── A/B testing (roadmap 6.4 / guide 7.3, 5.5) ───────────────────────────────

model AbTest {
  id              String           @id @default(cuid())
  merchantId      String           @map("merchant_id")
  name            String
  entityType      AbTestEntityType @map("entity_type")
  entityId        String?          @map("entity_id") // the tested campaign/template/element (nullable until attached)
  variants        Json // [{ id, name, config, allocationPct, metrics }]
  winnerMetric    String           @map("winner_metric") // "open_rate" | "click_rate" | "conversion_rate" | "revenue"
  winnerVariantId String?          @map("winner_variant_id") // null until decided
  status          AbTestStatus     @default(DRAFT)
  sampleSizePct   Int?             @map("sample_size_pct") // PLACEHOLDER
  confidenceLevel Float?           @map("confidence_level") // PLACEHOLDER: significance result
  startedAt       DateTime?        @map("started_at")
  endedAt         DateTime?        @map("ended_at")
  decidedAt       DateTime?        @map("decided_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([merchantId, entityType, entityId])
  @@map("ab_tests")
}

// ─── On-site personalization (roadmap 6.5 / guide 7.5) ────────────────────────

model OnSiteElement {
  id              String            @id @default(cuid())
  merchantId      String            @map("merchant_id")
  name            String
  type            OnSiteElementType
  config          Json // content/appearance (subtype lives here)
  segmentId       String?           @map("segment_id") // null = show to all visitors
  displayRules    Json              @map("display_rules") // triggers: exit-intent / timed / cart-value / page match
  status          String            @default("DRAFT") // "DRAFT" | "ACTIVE" | "PAUSED" | "ARCHIVED"
  priority        Int? // PLACEHOLDER: ordering when multiple match
  impressionCount Int               @default(0) @map("impression_count") // PLACEHOLDER: recomputed from ClickHouse
  conversionCount Int               @default(0) @map("conversion_count") // PLACEHOLDER: recomputed from ClickHouse
  startsAt        DateTime?         @map("starts_at") // PLACEHOLDER: scheduling
  endsAt          DateTime?         @map("ends_at") // PLACEHOLDER

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  segment  Segment? @relation(fields: [segmentId], references: [id], onDelete: SetNull)

  @@index([merchantId])
  @@index([merchantId, status])
  @@index([segmentId])
  @@map("onsite_elements")
}

// ─── COD verification (roadmap 6.4 / guide 7.4) ───────────────────────────────

model VerificationAttempt {
  id            String              @id @default(cuid())
  merchantId    String              @map("merchant_id")
  codOrderId    String              @map("cod_order_id")
  customerId    String?             @map("customer_id") // PLACEHOLDER convenience: query attempts by customer
  channel       VerificationChannel
  status        VerificationStatus  @default(PENDING)
  attemptNumber Int                 @default(1) @map("attempt_number") // 1 = first, 2 = reminder, …
  sentAt        DateTime?           @map("sent_at")
  respondedAt   DateTime?           @map("responded_at")
  response      String? // raw reply "YES" / "NO" / IVR digit
  messageId     String?             @map("message_id") // PLACEHOLDER: the outbound verification Message

  createdAt DateTime @default(now()) @map("created_at")

  merchant Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  codOrder CodOrder  @relation(fields: [codOrderId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  message  Message?  @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@unique([codOrderId, attemptNumber])
  @@index([merchantId])
  @@index([merchantId, status])
  @@index([codOrderId])
  @@index([customerId])
  @@index([messageId])
  @@map("verification_attempts")
}

// ─── Two-way WhatsApp conversation (roadmap 6.3-6.4 / guide 7.2) ───────────────

model WhatsAppConversation {
  id                  String                    @id @default(cuid())
  merchantId          String                    @map("merchant_id")
  customerId          String?                   @map("customer_id")
  phone               String // E.164 counterpart — match inbound when customerId is null
  contextType         String                    @map("context_type") // "verification" | "journey_reply" (String: likely to grow)
  contextId           String?                   @map("context_id") // id of verif attempt / journey enrollment / cod order
  awaitingReplyUntil  DateTime?                 @map("awaiting_reply_until")
  state               WhatsAppConversationState @default(OPEN)
  lastInboundAt       DateTime?                 @map("last_inbound_at") // PLACEHOLDER: 24h window tracking
  lastOutboundAt      DateTime?                 @map("last_outbound_at") // PLACEHOLDER
  journeyEnrollmentId String?                   @map("journey_enrollment_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  merchant          Merchant           @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  customer          Customer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  journeyEnrollment JourneyEnrollment? @relation(fields: [journeyEnrollmentId], references: [id], onDelete: SetNull)

  // NOTE: a partial UNIQUE (merchant_id, phone) WHERE state = 'OPEN' is added as raw SQL in the
  // migration (Prisma cannot express a partial-unique index) to guarantee one OPEN conversation per phone.
  @@index([merchantId])
  @@index([merchantId, phone])
  @@index([customerId])
  @@index([journeyEnrollmentId])
  @@map("whatsapp_conversations")
}

// ─── Pre-built flow library (roadmap 6.5 / guide 7.6) — SYSTEM/GLOBAL, no merchantId ──

model FlowTemplate {
  id              String    @id @default(cuid())
  key             String    @unique // stable id, e.g. "abandoned_cart_whatsapp_first"
  name            String
  category        String // "abandoned_cart" | "welcome" | "post_purchase" | "win_back" | "loyalty_vip" | "cod"
  description     String
  graphJson       Json      @map("graph_json") // journey graph cloned into journey_steps on activation
  channels        Channel[] // channels the flow uses
  isSystem        Boolean   @default(true) @map("is_system")
  isActive        Boolean   @default(true) @map("is_active") // PLACEHOLDER: retire a system flow
  icon            String? // PLACEHOLDER: catalog UI
  previewImageUrl String?   @map("preview_image_url") // PLACEHOLDER
  sortOrder       Int?      @map("sort_order") // PLACEHOLDER

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@map("flow_templates")
}

// ─── Web Push ─────────────────────────────────────────────────────────────────

model PushSubscription {
  id         String    @id @default(cuid())
  merchantId String    @map("merchant_id")
  customerId String    @map("customer_id")
  endpoint   String // push-service endpoint (the unique subscription id)
  keys       Json // { p256dh, auth } Web Push encryption keys
  userAgent  String?   @map("user_agent")
  isActive   Boolean   @default(true) @map("is_active")
  lastUsedAt DateTime? @map("last_used_at") // PLACEHOLDER
  expiredAt  DateTime? @map("expired_at") // PLACEHOLDER

  createdAt DateTime @default(now()) @map("created_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([merchantId, endpoint])
  @@index([merchantId])
  @@index([customerId])
  @@map("push_subscriptions")
}

// ─── Courier integrations (roadmap 8.1 / guide 9.2) ───────────────────────────

model CourierShipment {
  id             String         @id @default(cuid())
  merchantId     String         @map("merchant_id")
  orderId        String?        @map("order_id")
  codOrderId     String?        @map("cod_order_id") // PLACEHOLDER: link for COD acceptance-rate updates
  customerId     String?        @map("customer_id") // PLACEHOLDER convenience
  courier        Courier
  trackingNumber String?        @map("tracking_number") // nullable: some couriers book first, tracking arrives async
  status         ShipmentStatus @default(CREATED)
  codAmount      Decimal?       @map("cod_amount") @db.Decimal(12, 2) // PLACEHOLDER
  codCollected   Boolean        @default(false) @map("cod_collected")
  codCollectedAt DateTime?      @map("cod_collected_at") // PLACEHOLDER
  returnReason   String?        @map("return_reason")
  dispatchedAt   DateTime?      @map("dispatched_at")
  deliveredAt    DateTime?      @map("delivered_at")
  returnedAt     DateTime?      @map("returned_at")
  rawTracking    Json?          @map("raw_tracking") // PLACEHOLDER: last raw courier payload

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  merchant Merchant       @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  order    Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  codOrder CodOrder?      @relation(fields: [codOrderId], references: [id], onDelete: SetNull)
  customer Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  events   CourierEvent[]

  @@unique([merchantId, courier, trackingNumber])
  @@index([merchantId])
  @@index([merchantId, status])
  @@index([orderId])
  @@index([codOrderId])
  @@index([customerId])
  @@map("courier_shipments")
}

model CourierEvent {
  id          String         @id @default(cuid())
  merchantId  String         @map("merchant_id") // direct for tenant safety (log-child, like Message/CampaignRecipient)
  shipmentId  String         @map("shipment_id")
  status      ShipmentStatus
  description String? // PLACEHOLDER: human-readable courier status
  externalId  String?        @map("external_id") // courier's event id (dedup)
  raw         Json? // raw courier webhook/poll payload
  occurredAt  DateTime       @map("occurred_at")

  createdAt DateTime @default(now()) @map("created_at")

  merchant Merchant        @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  shipment CourierShipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@unique([shipmentId, externalId]) // dedup polled events (NULLs are distinct → un-id'd events still insert)
  @@index([merchantId])
  @@index([shipmentId])
  @@index([shipmentId, occurredAt])
  @@map("courier_events")
}

// ─── Public REST API & outbound webhooks (roadmap 8.2 / guide 9.3) ────────────

model OutboundWebhook {
  id          String   @id @default(cuid())
  merchantId  String   @map("merchant_id")
  url         String
  events      String[] @default([]) // "segment.entered" | "campaign.completed" | "cod.verification_result" | …
  secret      String // merchant-owned HMAC signing secret — SECURITY: encrypt at rest (app-layer/KMS)
  isActive    Boolean  @default(true) @map("is_active")
  description String? // PLACEHOLDER

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  merchant   Merchant          @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([merchantId])
  @@map("outbound_webhooks")
}

model WebhookDelivery {
  id          String    @id @default(cuid())
  merchantId  String    @map("merchant_id")
  webhookId   String    @map("webhook_id")
  event       String
  payload     Json
  statusCode  Int?      @map("status_code") // null until a response is received
  attempts    Int       @default(0)
  success     Boolean   @default(false) // PLACEHOLDER
  error       String? // PLACEHOLDER
  nextRetryAt DateTime? @map("next_retry_at") // PLACEHOLDER: backoff scheduling
  deliveredAt DateTime? @map("delivered_at") // PLACEHOLDER

  createdAt DateTime @default(now()) @map("created_at")

  merchant Merchant        @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  webhook  OutboundWebhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([webhookId])
  @@index([webhookId, createdAt])
  @@index([success, nextRetryAt]) // retry sweep: WHERE success = false AND nextRetryAt <= now()
  @@map("webhook_deliveries")
}

// ─── Agency accounts (roadmap 8.3 / guide 9.4) — cross-merchant mapping ────────

model AgencyAssignment {
  id               String  @id @default(cuid())
  agencyMerchantId String  @map("agency_merchant_id")
  userId           String  @map("user_id")
  childMerchantId  String  @map("child_merchant_id")
  createdBy        String? @map("created_by") // PLACEHOLDER: who granted the assignment

  createdAt DateTime @default(now()) @map("created_at")

  agencyMerchant Merchant @relation("AgencyAssignmentAgency", fields: [agencyMerchantId], references: [id], onDelete: Cascade)
  childMerchant  Merchant @relation("AgencyAssignmentChild", fields: [childMerchantId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, childMerchantId])
  @@index([agencyMerchantId])
  @@index([userId])
  @@index([childMerchantId])
  @@map("agency_assignments")
}

// ─── Per-merchant provider credentials (WhatsApp / courier / SMS / SES / IVR) ──

model MerchantIntegration {
  id          String    @id @default(cuid())
  merchantId  String    @map("merchant_id")
  provider    String // "WHATSAPP" | "POSTEX" | "LEOPARDS" | "TCS" | "MP" | "TWILIO" | "SES" | "FIXERR"
  credentials Json // SECURITY: encrypt at rest (app-layer/KMS) — PLACEHOLDER
  config      Json? // non-secret config (phone_number_id, WABA id, from address)
  externalId  String?   @map("external_id") // e.g. WhatsApp phone_number_id — inbound-webhook → merchant routing
  status      String    @default("DISCONNECTED") // "CONNECTED" | "DISCONNECTED" | "ERROR"
  isActive    Boolean   @default(true) @map("is_active")
  connectedAt DateTime? @map("connected_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@unique([merchantId, provider]) // one integration per provider per merchant
  @@unique([provider, externalId]) // a provider external id (e.g. phone_number_id) maps to exactly one merchant
  @@index([merchantId])
  @@index([provider, externalId])
  @@map("merchant_integrations")
}

// ─── Per-merchant settings (COD / fake-order / attribution / email / white-label) ──

model MerchantSettings {
  id                  String @id @default(cuid())
  merchantId          String @unique @map("merchant_id") // one row per merchant
  codVerification     Json?  @map("cod_verification") // PLACEHOLDER: channel, reminder cadence, auto-cancel window (7.4)
  fakeOrderThresholds Json?  @map("fake_order_thresholds") // PLACEHOLDER: { process, verify, cancel } bands (7.3/8.5)
  attributionWindows  Json?  @map("attribution_windows") // PLACEHOLDER: per-channel windows (email 7d / sms 24h / wa 3d)
  emailDefaults       Json?  @map("email_defaults") // PLACEHOLDER: from-name, reply-to
  branding            Json? // PLACEHOLDER: white-label logo / color / company / footer (9.4)
  extra               Json? // PLACEHOLDER: forward-compat catch-all

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@map("merchant_settings")
}

// ─── AI copywriter audit / cost trail (roadmap 7.4 / guide 8.3) ───────────────

model AiGeneration {
  id               String   @id @default(cuid())
  merchantId       String   @map("merchant_id")
  userId           String?  @map("user_id") // soft ref to the requesting user (no FK)
  purpose          String // "email_subject" | "whatsapp_body" | "sms_copy" | …
  channel          String? // target channel if applicable
  language         String? // "en" | "ur"
  contextJson      Json?    @map("context_json") // goal / segment / offer / tone inputs
  variants         Json // the generated variants
  chosenIndex      Int?     @map("chosen_index") // which variant the merchant kept
  model            String? // LLM model id
  promptTokens     Int?     @map("prompt_tokens") // PLACEHOLDER: cost trail
  completionTokens Int?     @map("completion_tokens") // PLACEHOLDER
  costUsd          Decimal? @map("cost_usd") @db.Decimal(10, 4) // PLACEHOLDER

  createdAt DateTime @default(now()) @map("created_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([merchantId, purpose])
  @@map("ai_generations")
}
